# 来源读取设置。
# 如果使用 Codex 读取网页，下面三项可以留空。
# 这里填写资讯详情页读取服务名称，例如后续使用的检索或网页抽取服务。
SEARCH_PROVIDER=
# 这里填写资讯详情页读取 API key。不要提交真实 key。
SEARCH_API_KEY=
# 这里填写资讯详情页读取 API 地址。可填写官方地址、代理地址或企业网关地址。
SEARCH_API_ENDPOINT=
# 这里填写检索结果数量上限。
SEARCH_MAX_RESULTS=5
# 这里填写每次读取资讯详情页的等待秒数。
SOURCE_FETCH_TIMEOUT_SECONDS=20

# 图片生成设置。
# 如果使用 Codex 宿主生图，下面四项可以留空。
# 这里填写图片生成服务名称。后续可使用 OpenAI Images API。
IMAGE_PROVIDER=
# 这里填写图片生成 API key。不要提交真实 key。
IMAGE_API_KEY=
# 这里填写图片生成 API 地址。可填写官方地址、代理地址或企业网关地址。
IMAGE_API_ENDPOINT=
# 这里填写图片生成模型名称。启用图片 API 时再填写。
IMAGE_MODEL=
# 这里填写目标图片尺寸。Moomoo 话题背景图默认使用 750x375。
IMAGE_SIZE=750x375

# 宿主能力声明。
# available 表示当前工具环境可直接读取网页或生成图片。
# unavailable 表示当前工具环境没有该能力。
# unknown 表示暂未确认。
# 这里声明 Codex 或其他宿主是否能读取网页。
HOST_WEB_READER=unknown
# 这里声明 Codex 或其他宿主是否能生成图片。
HOST_IMAGE_TOOL=unknown

# 输出设置。
# 这里填写话题包和中间产物保存目录。
OUTPUT_ROOT=outputs/runs
# 这里填写默认发布平台。
DEFAULT_PLATFORM=moomoo
